# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in your values.
#
# NEVER commit .env to version control. This file (.env.example) is safe
# to commit because it contains no real secrets — only placeholder values
# that document what's needed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Groq API Orchestrator"
APP_VERSION="1.0.0"
DEBUG=false
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
# Development: SQLite (no setup required)
DATABASE_URL=sqlite+aiosqlite:///./grok_orchestrator.db

# Production: PostgreSQL (uncomment and fill in)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/grok_orchestrator

# ── Grok API ──────────────────────────────────────────────────────────────────
GROK_BASE_URL=https://api.x.ai/v1
GROK_DEFAULT_MODEL=grok-3
GROK_REQUEST_TIMEOUT=30.0

# ── Orchestration ─────────────────────────────────────────────────────────────
MAX_RETRIES=3
COOLDOWN_SECONDS=60
FAILURE_THRESHOLD=5
LATENCY_EWMA_ALPHA=0.2

# ── Scoring weights (must conceptually add to 1.0) ────────────────────────────
SCORE_WEIGHT_FAIL_COUNT=0.4
SCORE_WEIGHT_LATENCY=0.4
SCORE_WEIGHT_LAST_USED=0.2

# ── Security ──────────────────────────────────────────────────────────────────
API_SECRET_KEY=change-me-to-a-long-random-string
ADMIN_API_KEY=change-me-to-another-long-random-string
